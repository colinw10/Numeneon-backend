  // --- Essential Editor Settings ---
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.fontLigatures": true,
  "editor.fontVariations": false,
  "editor.fontFamily": "Fira Code, Menlo, Monaco, 'Courier New', monospace",
  "editor.formatOnSave": true,
  "editor.minimap.enabled": false,
  "editor.accessibilitySupport": "off",
  "editor.maxTokenizationLineLength": 200000,
  // --- Workbench & Theming ---
  "workbench.iconTheme": "material-icon-theme",
  "workbench.settings.applyToAllProfiles": [
    "workbench.colorCustomizations"
  ],
  // --- Terminal Settings ---
  "terminal.integrated.fontFamily": "Hack, Inconsolata, monospace",
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.fontLigatures.enabled": true,
  // --- Other Settings ---
  "files.autoSave": "afterDelay",
  "liveServer.settings.CustomBrowser": "chrome",
  "liveServer.settings.donotShowInfoMsg": true,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "workbench.editor.empty.hint": "hidden",
  // --- External Feature Management ---
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "postman.mcp.notifications.postmanMCP": false,
  "chat.instructionsFilesLocations": {
    ".github/instructions": true,
    "/var/folders/5z/g1vdz5ws5rl33x_qyxvlgw1r0000gn/T/postman-collections-post-response.instructions.md": true,
    "/var/folders/5z/g1vdz5ws5rl33x_qyxvlgw1r0000gn/T/postman-collections-pre-request.instructions.md": true,
    "/var/folders/5z/g1vdz5ws5rl33x_qyxvlgw1r0000gn/T/postman-folder-post-response.instructions.md": true,
    "/var/folders/5z/g1vdz5ws5rl33x_qyxvlgw1r0000gn/T/postman-folder-pre-request.instructions.md": true,
    "/var/folders/5z/g1vdz5ws5rl33x_qyxvlgw1r0000gn/T/postman-http-request-post-response.instructions.md": true,
    "/var/folders/5z/g1vdz5ws5rl33x_qyxvlgw1r0000gn/T/postman-http-request-pre-request.instructions.md": true
  },
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },
  "security.workspace.trust.untrustedFiles": "open",
  "terminal.integrated.initialHint": false
}
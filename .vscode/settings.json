{
  // --- Cosmo Black Theme ---
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "Comments - Muted Grey (italic)",
        "scope": [
          "comment",
          "comment.line",
          "comment.block",
          "punctuation.definition.comment"
        ],
        "settings": {
          "foreground": "#6b7280",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Keywords - Cobalt Blue",
        "scope": [
          "keyword",
          "keyword.control",
          "keyword.operator.new",
          "keyword.operator.expression",
          "keyword.operator.logical",
          "storage.type",
          "storage.modifier"
        ],
        "settings": {
          "foreground": "#6495ed"
        }
      },
      {
        "name": "Functions - Coral/Salmon",
        "scope": [
          "entity.name.function",
          "meta.function-call",
          "support.function",
          "meta.method-call"
        ],
        "settings": {
          "foreground": "#e06c75"
        }
      },
      {
        "name": "Strings - Muted Gold",
        "scope": [
          "string",
          "string.quoted",
          "string.template",
          "punctuation.definition.string"
        ],
        "settings": {
          "foreground": "#c4a35a"
        }
      },
      {
        "name": "Numbers - Soft Lavender",
        "scope": [
          "constant.numeric",
          "constant.language",
          "constant.character"
        ],
        "settings": {
          "foreground": "#c5a5c5"
        }
      },
      {
        "name": "Variables - Soft White",
        "scope": [
          "variable",
          "variable.other",
          "variable.parameter"
        ],
        "settings": {
          "foreground": "#d1d5db"
        }
      },
      {
        "name": "Properties/Keys - Teal",
        "scope": [
          "variable.other.property",
          "meta.object-literal.key",
          "support.type.property-name"
        ],
        "settings": {
          "foreground": "#82c4c4"
        }
      },
      {
        "name": "Classes & Types - Coral",
        "scope": [
          "entity.name.class",
          "entity.name.type",
          "support.class",
          "support.type"
        ],
        "settings": {
          "foreground": "#e06c75"
        }
      },
      {
        "name": "Decorators - Gold",
        "scope": [
          "meta.decorator",
          "entity.name.function.decorator"
        ],
        "settings": {
          "foreground": "#d4a656",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Arrow/Operators - Coral",
        "scope": [
          "keyword.operator",
          "punctuation.accessor",
          "storage.type.function.arrow"
        ],
        "settings": {
          "foreground": "#e06c75"
        }
      },
      {
        "name": "Punctuation - Muted Grey",
        "scope": [
          "punctuation.bracket",
          "punctuation.separator",
          "meta.brace"
        ],
        "settings": {
          "foreground": "#9ca3af"
        }
      }
    ]
  },
  "workbench.colorCustomizations": {
    "editor.background": "#0d0e14",
    "editor.foreground": "#d1d5db",
    "editorLineNumber.foreground": "#3a3f52",
    "editorLineNumber.activeForeground": "#8b5cf6",
